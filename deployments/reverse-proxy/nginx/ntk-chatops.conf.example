##
# NetToolsKit ChatOps reverse-proxy reference profile (Nginx)
# - Terminates TLS in proxy layer
# - Exposes only ChatOps ingress endpoints
# - Preserves signature/token headers required by service ingress validation
#
# Replace placeholders before production usage.
##

upstream ntk_service {
    server 127.0.0.1:8080;
    keepalive 32;
}

server {
    listen 443 ssl http2;
    server_name ntk.example.com;

    ssl_certificate /etc/letsencrypt/live/ntk.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/ntk.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "no-referrer" always;

    client_max_body_size 128k;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 30s;
    proxy_send_timeout 30s;

    # Optional: lock health endpoints to private addresses.
    location = /health {
        allow 127.0.0.1;
        allow ::1;
        deny all;
        proxy_pass http://ntk_service;
    }

    location = /ready {
        allow 127.0.0.1;
        allow ::1;
        deny all;
        proxy_pass http://ntk_service;
    }

    location = /chatops/telegram/webhook {
        limit_except POST { deny all; }
        proxy_set_header X-Telegram-Bot-Api-Secret-Token $http_x_telegram_bot_api_secret_token;
        proxy_pass http://ntk_service;
    }

    location = /chatops/discord/interactions {
        limit_except POST { deny all; }
        proxy_set_header X-Signature-Ed25519 $http_x_signature_ed25519;
        proxy_set_header X-Signature-Timestamp $http_x_signature_timestamp;
        proxy_pass http://ntk_service;
    }

    # Deny any unexpected path.
    location / {
        return 404;
    }
}