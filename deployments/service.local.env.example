# NetToolsKit service mode local environment example
NTK_RUNTIME_MODE=service
NTK_LOG_LEVEL=info
NTK_SERVICE_AUTH_TOKEN=local-service-token
NTK_SERVICE_HTTP_TIMEOUT_MS=30000
NTK_TASK_MAX_CONCURRENCY=2
NTK_TASK_MAX_RETRIES=2
NTK_TASK_QUEUE_CAPACITY=128
NTK_SERVICE_AUTOMATION_PROFILE=balanced
NTK_SERVICE_ALLOWED_INTENTS=ai-ask,ai-plan,ai-explain,ai-apply-dry-run,repo-workflow
NTK_SERVICE_SUBMIT_BUDGET=60
NTK_SERVICE_SUBMIT_WINDOW_SECONDS=60
NTK_SERVICE_MAX_PAYLOAD_BYTES=8192
NTK_SERVICE_MAX_INFLIGHT_TASKS=64
# Optional ChatOps Telegram webhook mode (local persistence only)
# NTK_CHATOPS_ENABLED=true
# NTK_CHATOPS_TELEGRAM_TOKEN=replace-with-bot-token
# NTK_CHATOPS_TELEGRAM_WEBHOOK_ENABLED=true
# NTK_CHATOPS_DISCORD_TOKEN=replace-with-bot-token
# NTK_CHATOPS_DISCORD_INTERACTIONS_ENABLED=true
# NTK_CHATOPS_TELEGRAM_WEBHOOK_SECRET_TOKEN=replace-with-webhook-secret-token
# NTK_CHATOPS_DISCORD_INTERACTIONS_PUBLIC_KEY=replace-with-discord-public-key-hex
# NTK_CHATOPS_INGRESS_REPLAY_WINDOW_SECONDS=300
# NTK_CHATOPS_INGRESS_REPLAY_MAX_ENTRIES=4096
# NTK_CHATOPS_INGRESS_REPLAY_BACKEND=file
# NTK_CHATOPS_INGRESS_REPLAY_FILE_PATH=/var/lib/ntk/chatops/ingress-replay-cache.json
# NTK_CHATOPS_ALLOWED_USERS=777
# NTK_CHATOPS_ALLOWED_CHANNELS=555
# NTK_CHATOPS_RATE_LIMIT_PER_USER=10
# NTK_CHATOPS_RATE_LIMIT_PER_CHANNEL=30
# NTK_CHATOPS_RATE_LIMIT_STRATEGY=token_bucket
# NTK_CHATOPS_RATE_LIMIT_AUTOTUNE_PROFILE=balanced
# NTK_CHATOPS_RATE_LIMIT_BURST_PER_USER=20
# NTK_CHATOPS_RATE_LIMIT_BURST_PER_CHANNEL=60
# NTK_CHATOPS_RATE_LIMIT_WINDOW_SECONDS=60
XDG_DATA_HOME=/var/lib/ntk
XDG_CONFIG_HOME=/var/lib/ntk/config